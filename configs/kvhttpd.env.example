# httpkvdb environment configuration template.
#
# Copy this file to a private location, edit values, then start kvhttpd
# with --config. Example:
#
#   cp ./configs/kvhttpd.env.example .env.local
#   ./bin/kvhttpd --config .env.local
#
# Keep this file private. It contains secret material.

# Address listened on by the HTTP server.
KVHTTP_ADDR=0.0.0.0:8080

# Comma-separated browser origins allowed by CORS.
# Vite local development commonly uses http://127.0.0.1:5173.
# Use "*" only for private local debugging, not for production exposure.
KVHTTP_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Durable local storage directory.
# The current implementation stores data in ${KVHTTP_STORAGE_PATH}/httpkvdb.json.
KVHTTP_STORAGE_PATH=./data

# Limits.
KVHTTP_MAX_KEY_SIZE=4096
KVHTTP_MAX_VALUE_SIZE=104857600
KVHTTP_MAX_TX_OPS=1000

# Transaction timeouts and cleanup.
KVHTTP_DEFAULT_TX_TIMEOUT_MS=30000
KVHTTP_MAX_TX_TIMEOUT_MS=300000
KVHTTP_TX_CLEAN_INTERVAL_MS=5000
KVHTTP_TX_RESULT_RETENTION_MS=3600000

# Auth cache.
KVHTTP_AUTH_CACHE_TTL_MS=60000
KVHTTP_AUTH_CACHE_MAX_ENTRIES=10000

# Bootstrap principal.
# On first startup, the server creates this initial user and API key mapping.
# The API key is stored as a SHA-256 hash, not as plaintext.
KVHTTP_BOOTSTRAP_USER_ID=admin
KVHTTP_BOOTSTRAP_USERSPACE_ID=admin_space

# Change this before production use.
KVHTTP_BOOTSTRAP_API_KEY=replace-with-a-long-random-local-secret

# JWT validation.
# JWT uses HS256 in this implementation.
# Change this before production use.
KVHTTP_JWT_SECRET=replace-with-a-long-random-jwt-secret

# Optional JWT issuer and audience checks.
# Leave empty to disable each check.
KVHTTP_JWT_ISSUER=
KVHTTP_JWT_AUDIENCE=
